#############################################################################
# 7. Objectives / Motivation
#############################################################################

dtm-business:RightsHolderMotivationShape
    a sh:NodeShape ;
    sh:targetClass dtm-core:AffectedParty ;

    sh:property [
        sh:path dtm-business:hasRightsHolderMotivation ;
        sh:minCount 1 ;
        sh:severity sh:Info ;
        sh:message "Für Rechtehalte kann eine Motivation angegeben werden."@de ;
    ] .

dtm-business:DataHolderMotivationShape
    a sh:NodeShape ;
    sh:targetClass dtm-core:DataOwner ;

    sh:property [
        sh:path dtm-business:hasDataHolderMotivation ;
        sh:minCount 1 ;
        sh:severity sh:Info ;
        sh:message "Für Datenhalter kann eine Motivation angegeben werden."@de ;
    ] .

dtm-business:DataConsumerMotivationShape
    a sh:NodeShape ;
    sh:targetClass dtm-core:DataConsumer ;

    sh:property [
        sh:path dtm-business:hasDataConsumerMotivation ;
        sh:minCount 1 ;
        sh:severity sh:Info ;
        sh:message "Für Datennutzer kann eine Motivation angegeben werden."@de ;
    ] .

