        rdfs:label           "Data Owner"@en , "Dateninhaber"@de;
        rdfs:subClassOf      owl:Thing , rdfs:Resource , dtm-core:DataProvider , dtm-core:DataOwner , dtm-core:Actor;
        owl:equivalentClass  dtm-core:DataOwner .

