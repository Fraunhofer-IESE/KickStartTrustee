        owl:equivalentProperty  rdfs:domain .

rdfs:Resource  rdf:type      rdfs:Class , owl:Class , rdfs:Resource;
        rdfs:subClassOf      rdfs:Resource;
        owl:equivalentClass  rdfs:Resource .

owl:imports  rdf:type           rdf:Property , owl:OntologyProperty , rdfs:Resource;
