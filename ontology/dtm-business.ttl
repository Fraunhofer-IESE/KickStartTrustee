    skos:inScheme dtm-business:PayModelScheme ;
    skos:broader  dtm-business:PayModel ;
    rdfs:label    "Support Fee"@en ,
                  "Supportgebühr"@de ;
    rdfs:comment  "Pay model that charges fees for support, maintenance or operational assistance."@en ,
                  "Bezahlmodell, bei dem Entgelte für Support, Wartung oder Betriebsunterstützung anfallen."@de .


###  https://tool.kickstarttrustee.de/ontology/dtm-business#UsageGoalOfUser
dtm-business:UsageGoalOfUser rdf:type owl:Class ;
    rdfs:label   "Nutzungsziel des Nutzers"@de ,
