# Disjointness der UsageGoalOfUser-Unterklassen
[ rdf:type   owl:AllDisjointClasses ;
  owl:members ( dtm-business:DataAccess
                dtm-business:DataAnalysis
                dtm-business:DataQualityManagement
                dtm-business:DataSharing
              )
] .


