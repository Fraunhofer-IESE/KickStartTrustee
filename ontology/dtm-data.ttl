@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml:   <http://www.w3.org/XML/1998/namespace> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:  <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dtm-core: <https://forgetrustee.kickstarttrustee.de/ontology/dtm-core#> .
@prefix dtm-data: <https://forgetrustee.kickstarttrustee.de/ontology/dtm-data#> .
@prefix dpv:   <https://w3id.org/dpv#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix schema: <https://schema.org/> .

<https://forgetrustee.kickstarttrustee.de/ontology/dtm-data> a owl:Ontology ;
    dcterms:creator  "Bernd Rauch", "Denis Feth", "Jessica Chwalek" ;
    dcterms:license  <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2025-11-10"^^xsd:date ;
    dcterms:publisher "Kickstart Trustee" ;
    dcterms:rights   "© 2025 Kickstart Trustee — CC BY 4.0" ;
    owl:versionIRI   <https://forgetrustee.kickstarttrustee.de/ontology/dtm-data/0.1.0> ;
    owl:imports      <https://forgetrustee.kickstarttrustee.de/ontology/dtm-core> ;
    dcterms:title       "DTM Data Ontology"@en ;
    dcterms:description "Data layer extending the DTM core ontology."@en ;
    dcterms:description "Daten-Schicht, die die DTM-Core-Ontologie um datenspezifische Konzepte erweitert."@de ;
    vann:preferredNamespacePrefix "dtm-data" ;
    vann:preferredNamespaceUri    "https://forgetrustee.kickstarttrustee.de/ontology/dtm-data#" .


#################################################################
#    Object Properties
#################################################################

###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasForwardingFrequency
dtm-data:hasForwardingFrequency rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:DataForwarding ;
    rdfs:range dtm-data:Frequency ;
    rdfs:label "has forwarding frequency"@en ,
               "hat Weitergabefrequenz"@de ;
    rdfs:comment "Verknüpft eine Datenweitergabestufe mit der Häufigkeit, mit der Daten weitergegeben werden."@de ,
               "Links a data forwarding stage to the frequency with which data is forwarded."@en .



###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasForwardingTechnique
dtm-data:hasForwardingTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isForwardingTechniqueOf ;
    rdfs:domain dtm-data:DataForwarding ;
    rdfs:range dtm-data:ForwardingTechnique ;
    rdfs:label "has forwarding technique"@en ,
               "hat Weitergabetechnik"@de ;
    rdfs:comment "Gibt die technische Methode an, mit der Daten weitergegeben werden."@de ,
                 "Specifies the technical method used to forward data."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasPreparationTechnique
dtm-data:hasPreparationTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isPreparationTechniqueOf ;
    rdfs:domain dtm-data:DataPreparation ;
    rdfs:range dtm-data:PreparationTechnique ;
    rdfs:label "has preparation technique"@en ,
               "hat Aufbereitungstechnik"@de ;
    rdfs:comment "Gibt an, welche Verarbeitungstechnik in der Datenaufbereitung angewendet wird."@de ,
                 "Indicates which preparation technique is applied during data preparation."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasDataAnalysisTechnique
dtm-data:hasDataAnalysisTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isDataAnalysisTechniqueOf ;
    rdfs:domain dtm-data:DataAnalysis ;
    rdfs:range dtm-data:AnalysisTechnique ;
    rdfs:label "has data analysis technique"@en ,
               "hat Datenanalysetechnik"@de ;
    rdfs:comment "Gibt an, welche Datenanalysetechnik in der Datenanalyse angewendet wird."@de ,
                 "Indicates which data analysis technique is applied during data analysis."@en .



###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasReceptionFrequency
dtm-data:hasReceptionFrequency rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:DataReception ;
    rdfs:range dtm-data:Frequency ;
    rdfs:label "has reception frequency"@en ,
               "hat Empfangsfrequenz"@de ;
    rdfs:comment "Verknüpft eine Datenempfangsphase mit der Häufigkeit, mit der Daten empfangen werden."@de ,
                 "Links a data reception stage to the frequency with which data is received."@en .



###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasReceptionTechnique
dtm-data:hasReceptionTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isReceptionTechniqueOf ;
    rdfs:domain dtm-data:DataReception ;
    rdfs:range dtm-data:ReceptionTechnique ;
    rdfs:label "has reception technique"@en ,
               "hat Empfangstechnik"@de ;
    rdfs:comment "Gibt die Technik an, über die Daten empfangen werden."@de ,
                 "Specifies the technique or channel by which data is received."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasRetentionPeriod
dtm-data:hasRetentionPeriod rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:DataStorage ;
    rdfs:range dtm-data:RetentionPeriod ;
    rdfs:label "has retention period"@en ,
               "hat Speicherdauer"@de ;
    rdfs:comment "Verknüpft eine Speicherphase mit der Aufbewahrungsdauer."@de ,
                 "Relates a storage stage to the period for which data is retained."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#hasStorageTechnique
dtm-data:hasStorageTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isStorageTechniqueOf ;
    rdfs:domain dtm-data:DataStorage ;
    rdfs:range dtm-data:StorageTechnique ;
    rdfs:label "has storage technique"@en ,
               "hat Speichertechnik"@de ;
    rdfs:comment "Gibt die Speichertechnik an, die zum Speichern der Daten genutzt wird."@de ,
                 "Indicates the technical approach used to store data."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#implementedOn
dtm-data:implementedOn rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:isImplementedBy ;
    rdfs:domain dtm-core:DataTrusteeModel ;
    rdfs:range dtm-data:Architecture ;
    rdfs:label "implemented on"@en ,
               "implementiert auf"@de ;
    rdfs:comment "Verknüpft ein Datentreuhandmodell mit der technischen Architektur, auf der es implementiert ist."@de ,
                 "Relates a trustee model to the technical architecture it is implemented on."@en .



###  https://tool.kickstarttrustee.de/ontology/dtm-data#isForwardingFrequencyOf
dtm-data:isForwardingFrequencyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:Frequency ;
    rdfs:range dtm-data:DataForwarding ;
    rdfs:label "is forwarding frequency of"@en ,
               "ist Weitergabefrequenz von"@de ;
    rdfs:comment "Gibt die Weitergabestufe an, für die diese Frequenz gilt."@de ,
                 "Indicates the data forwarding stage this frequency applies to."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isForwardingTechniqueOf
dtm-data:isForwardingTechniqueOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:ForwardingTechnique ;
    rdfs:range dtm-data:DataForwarding ;
    rdfs:label "is forwarding technique of"@en ,
               "ist Weitergabetechnik von"@de ;
    rdfs:comment "Gibt an, in welcher Weitergabestufe diese Technik genutzt wird."@de ,
                 "Indicates the forwarding stage in which this technique is used."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isImplementedBy
dtm-data:isImplementedBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:Architecture ;
    rdfs:range dtm-core:DataTrusteeModel ;
    rdfs:label "is implemented by"@en ,
               "wird implementiert durch"@de ;
    rdfs:comment "Verknüpft eine Architektur mit dem darauf implementierten Datentreuhandmodell."@de ,
                 "Relates an architecture to the trustee model implemented on it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isPreparationTechniqueOf
dtm-data:isPreparationTechniqueOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:PreparationTechnique ;
    rdfs:range dtm-data:DataPreparation ;
    rdfs:label "is preparation technique of"@en ,
               "ist Aufbereitungstechnik von"@de ;
    rdfs:comment "Gibt die Aufbereitungsphase an, in der diese Technik genutzt wird."@de ,
                 "Indicates the data preparation stage in which this technique is applied."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#isDataAnalysisTechniqueOf
dtm-data:isDataAnalysisTechniqueOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:AnalysisTechnique ;
    rdfs:range dtm-data:DataAnalysis ;
    rdfs:label "is data analysis technique of"@en ,
               "ist Datenanalysetechnik von"@de ;
    rdfs:comment "Gibt die Analysephae an, in der diese Technik genutzt wird."@de ,
                 "Indicates the data analysis stage in which this technique is applied."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#isReceptionFrequencyOf
dtm-data:isReceptionFrequencyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:Frequency ;
    rdfs:range dtm-data:DataReception ;
    rdfs:label "is reception frequency of"@en ,
               "ist Empfangsfrequenz von"@de ;
    rdfs:comment "Gibt die Empfangsphase an, für die diese Frequenz gilt."@de ,
                 "Indicates the data reception stage this frequency applies to."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isReceptionTechniqueOf
dtm-data:isReceptionTechniqueOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:ReceptionTechnique ;
    rdfs:range dtm-data:DataReception ;
    rdfs:label "is reception technique of"@en ,
               "ist Empfangstechnik von"@de ;
    rdfs:comment "Gibt an, in welcher Empfangsphase diese Technik genutzt wird."@de ,
                 "Indicates the data reception stage in which this technique is used."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isRetentionPeriodOf
dtm-data:isRetentionPeriodOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:RetentionPeriod ;
    rdfs:range dtm-data:DataStorage ;
    rdfs:label "is retention period of"@en ,
               "ist Speicherdauer von"@de ;
    rdfs:comment "Gibt die Speicherphase an, für die diese Aufbewahrungsdauer gilt."@de ,
                 "Indicates the storage stage to which this retention period applies."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isStorageTechniqueOf
dtm-data:isStorageTechniqueOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:StorageTechnique ;
    rdfs:range dtm-data:DataStorage ;
    rdfs:label "is storage technique of"@en ,
               "ist Speichertechnik von"@de ;
    rdfs:comment "Gibt die Speicherphase an, in der diese Technik genutzt wird."@de ,
                 "Indicates the data storage stage in which this technique is used."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#isUsedAsSystem
dtm-data:isUsedAsSystem rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:usesSystem ;
    rdfs:domain dtm-data:DataSystem ;
    rdfs:range dtm-data:DataFlowComponent ;
    rdfs:label "is used as system"@en ,
               "wird genutzt als System in"@de ;
    rdfs:comment "Kennzeichnet, dass dieses System als technische Grundlage einer Datenflusskomponente dient."@de ,
                 "Indicates that this system is used to support a data flow component."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#performsForwarding
dtm-data:performsForwarding rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:stagePerformedBy ;
    owl:inverseOf dtm-data:triggersForwarding ;
    rdfs:domain dtm-data:DataForwarding ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "führt Weitergabe durch"@de ,
               "performs forwarding"@en ;
    rdfs:comment "Verknüpft eine Weitergabestufe mit dem Akteur, der sie durchführt."@de ,
                 "Links a data forwarding stage to the actor performing it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#performsPreparation
dtm-data:performsPreparation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:stagePerformedBy ;
    owl:inverseOf dtm-data:triggersPreparation ;
    rdfs:domain dtm-data:DataPreparation ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "führt Aufbereitung durch"@de ,
               "performs preparation"@en ;
    rdfs:comment "Verknüpft eine Aufbereitungsphase mit dem Akteur, der sie durchführt."@de ,
                 "Links a data preparation stage to the actor performing it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#performsReception
dtm-data:performsReception rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:stagePerformedBy ;
    owl:inverseOf dtm-data:triggersReception ;
    rdfs:domain dtm-data:DataReception ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "führt Empfang durch"@de ,
               "performs reception"@en ;
    rdfs:comment "Verknüpft eine Empfangsphase mit dem Akteur, der sie durchführt."@de ,
                 "Links a data reception stage to the actor performing it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#performsStorage
dtm-data:performsStorage rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:stagePerformedBy ;
    owl:inverseOf dtm-data:triggersStorage ;
    rdfs:domain dtm-data:DataStorage ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "führt Speicherung durch"@de ,
               "performs storage"@en ;
    rdfs:comment "Verknüpft eine Speicherphase mit dem Akteur, der sie durchführt."@de ,
                 "Links a data storage stage to the actor performing it."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#performsStorage
dtm-data:performsDataAnalysis rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:stagePerformedBy ;
    owl:inverseOf dtm-data:triggersDataAnalysis ;
    rdfs:domain dtm-data:DataAnalysis ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "führt Datenanalyse durch"@de ,
               "performs data analysis"@en ;
    rdfs:comment "Verknüpft eine Datenanalysephase mit dem Akteur, der sie durchführt."@de ,
                 "Links a data analysis stage to the actor performing it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#securedByTechnique
dtm-data:securedByTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:securesAsTechnique ;
    rdfs:domain dtm-data:DataFlowComponent ;
    rdfs:range dtm-data:SecurityReceptionTechnique ;
    rdfs:label "gesichert durch Maßnahme"@de ,
               "secured by technique"@en ;
    rdfs:comment "Gibt an, welche Sicherheitsmaßnahme auf diese Komponente angewendet wird."@de ,
                 "Indicates which security technique protects this flow component."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#securesAsTechnique
dtm-data:securesAsTechnique rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:SecurityReceptionTechnique ;
    rdfs:range dtm-data:DataFlowComponent ;
    rdfs:label "secures as technique"@en ,
               "sichert als Maßnahme"@de ;
    rdfs:comment "Verknüpft eine Sicherheitsmaßnahme mit der Komponente, die sie absichert."@de ,
                 "Relates a security technique to the component it protects."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#stagePerformedBy
dtm-data:stagePerformedBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:triggersStage ;
    rdfs:domain dtm-data:DataFlowComponent ;
    rdfs:range dtm-core:Actor ;
    rdfs:label "stage performed by"@en ,
               "Komponente durchgeführt durch"@de ;
    rdfs:comment "Verknüpft eine Datenflusskomponente mit dem Akteur, der sie ausführt."@de ,
                 "Relates a data flow component to the actor performing it."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersForwarding
dtm-data:triggersForwarding rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:triggersStage ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataForwarding ;
    rdfs:label "triggers forwarding"@en ,
               "veranlasst Weitergabe"@de ;
    rdfs:comment "Kennzeichnet einen Akteur als Auslöser einer Weitergabe."@de ,
                 "Indicates an actor triggering a forwarding stage."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersPreparation
dtm-data:triggersPreparation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:triggersStage ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataPreparation ;
    rdfs:label "triggers preparation"@en ,
               "veranlasst Aufbereitung"@de ;
    rdfs:comment "Kennzeichnet einen Akteur als Auslöser einer Aufbereitung."@de ,
                 "Indicates an actor triggering a preparation stage."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersReception
dtm-data:triggersReception rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:triggersStage ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataReception ;
    rdfs:label "triggers reception"@en ,
               "veranlasst Empfang"@de ;
    rdfs:comment "Kennzeichnet einen Akteur als Auslöser eines Empfangs."@de ,
                 "Indicates an actor triggering a reception stage."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersStage
dtm-data:triggersStage rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataFlowComponent ;
    rdfs:label "triggers stage"@en ,
               "startet Phase"@de ;
    rdfs:comment "Verknüpft einen Akteur mit einer ausgelösten Phase im Datenfluss."@de ,
                 "Links an actor to a triggered data flow stage."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersStorage
dtm-data:triggersStorage rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:triggersStage ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataStorage ;
    rdfs:label "triggers storage"@en ,
               "veranlasst Speicherung"@de ;
    rdfs:comment "Kennzeichnet einen Akteur als Auslöser einer Speicherung."@de ,
                 "Indicates an actor triggering a storage stage."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#triggersStorage
dtm-data:triggersDataAnalysis rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf dtm-data:triggersStage ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range dtm-data:DataAnalysis ;
    rdfs:label "triggers data analysis"@en ,
               "veranlasst Datenanalyse"@de ;
    rdfs:comment "Kennzeichnet einen Akteur als Auslöser einer Datenanalyse."@de ,
                 "Indicates an actor triggering a data analysis stage."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#usesSystem
dtm-data:usesSystem rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-data:DataFlowComponent ;
    rdfs:range dtm-data:DataSystem ;
    rdfs:label "uses system"@en ,
               "benutzt System"@de ;
    rdfs:comment "Gibt an, welches System zur Durchführung dieser Datenflusskomponente genutzt wird."@de ,
                 "Indicates which system is used to execute this data flow component."@en .

###  https://tool.kickstarttrustee.de/ontology/dtm-data#ownedByActor
dtm-data:ownedByActor a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf dtm-data:ownsSystem ;
    rdfs:domain dtm-data:DataSystem ;
    rdfs:range  dtm-core:Actor ;
    rdfs:label  "owned by actor"@en ,
                "gehört Akteur"@de ;
    rdfs:comment "Links a technical system to the actor who owns it (organizational or legal ownership)."@en ,
                 "Verknüpft ein technisches System mit dem Akteur, dem es gehört (organisatorisch oder rechtlich)."@de .

dtm-data:ownsSystem a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:domain dtm-core:Actor ;
    rdfs:range  dtm-data:DataSystem ;
    rdfs:label  "owns system"@en ,
                "besitzt System"@de ;
    rdfs:comment "Relates an actor to a technical system they own."@en ,
                 "Verknüpft einen Akteur mit einem technischen System, das er besitzt."@de .


#################################################################
#    Classes
#################################################################


###  https://tool.kickstarttrustee.de/ontology/dtm-data#AIPoweredAnalysis
dtm-data:AIPoweredAnalysis rdf:type owl:Class ;
    rdfs:subClassOf dtm-data:AnalysisTechnique ;
    rdfs:label "AI powered analysis"@en ,
               "KI-gestützte Auswertung"@de ;
    rdfs:comment "Analyse von Daten mittels KI, LLMs oder Machine Learning."@de ,
                 "Analysis of data using AI techniques such as ML or LLMs."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#API
dtm-data:ReceptionAPI rdf:type owl:Class ;
    rdfs:subClassOf dtm-data:ReceptionTechnique ;
    rdfs:label "API"@de ,
               "API"@en ;
    rdfs:comment "Empfang von Daten über eine Programmierschnittstelle."@de ,
                 "Reception of data through an application programming interface."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#Aggregation
dtm-data:Aggregation rdf:type owl:Class ;
    rdfs:subClassOf dtm-data:PreparationTechnique ;
    rdfs:label "Aggregation"@de ,
               "Aggregation"@en ;
    rdfs:comment "Zusammenführung einzelner Werte zu aggregierten Ergebnissen."@de ,
                 "Combining individual values into aggregated results."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#Analog
dtm-data:Analog rdf:type owl:Class ;
    rdfs:subClassOf dtm-data:ReceptionTechnique ;
    rdfs:label "Analog"@de ,
               "Analog"@en ;
    rdfs:comment "Empfang über analoge Kanäle oder nicht-digitale Medien."@de ,
                 "Reception through analogue channels or non-digital media."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#AnalysisTechnique
dtm-data:AnalysisTechnique rdf:type owl:Class ;
    rdfs:label "Data Analysis Technique"@en ,
               "Auswertungstechnik"@de ;
    rdfs:comment "Kategorie von Techniken zur Analyse von Daten."@de ,
                 "Category of techniques for analysing data."@en .


###  https://tool.kickstarttrustee.de/ontology/dtm-data#Anonymisation
dtm-data:Anonymisation rdf:type owl:Class ;
    rdfs:subClassOf dtm-data:SecurityReceptionTechnique ;
    rdfs:label "Anonymisation"@en ,
               "Anonymisieren"@de ;
