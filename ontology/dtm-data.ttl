#################################################################
#    External Alignments
#################################################################

# Align core processing stages with DPV processing concepts and PROV activities
dtm-data:DataFlowComponent rdfs:subClassOf prov:Activity .

dtm-data:DataReception   rdfs:subClassOf prov:Activity , dpv:Obtain .
dtm-data:DataForwarding  rdfs:subClassOf prov:Activity , dpv:Transfer .
dtm-data:DataStorage     rdfs:subClassOf prov:Activity , dpv:Storage .
dtm-data:DataAnalysis    rdfs:subClassOf prov:Activity , dpv:Use .

# Align technical systems with PROV and Schema.org
dtm-data:DataSystem      rdfs:subClassOf prov:SoftwareAgent ,
                                      schema:SoftwareApplication .

# Align security and PETs with DPV technical measures
dtm-data:SecurityReceptionTechnique rdfs:subClassOf dpv:TechnicalMeasure .
dtm-data:PrivacyEnhancingTechnology rdfs:subClassOf dpv:TechnicalMeasure .

# Align retention modelling with DPV storage duration
dtm-data:RetentionPeriod rdfs:subClassOf dpv:StorageDuration .

# Align retention property with DPV property
dtm-data:hasRetentionPeriod rdfs:subPropertyOf dpv:hasStorageDuration .

# Align system usage and implementation with PROV usage
dtm-data:usesSystem      rdfs:subPropertyOf prov:used .
dtm-data:implementedOn   rdfs:subPropertyOf prov:used .

# Align actor ↔ stage relations with PROV association
dtm-data:stagePerformedBy     rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:performsReception    rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:performsForwarding   rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:performsPreparation  rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:performsStorage      rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:triggersStage        rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:triggersReception    rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:triggersForwarding   rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:triggersPreparation  rdfs:subPropertyOf prov:wasAssociatedWith .
dtm-data:triggersStorage      rdfs:subPropertyOf prov:wasAssociatedWith .


#################################################################
#    General axioms
#################################################################

