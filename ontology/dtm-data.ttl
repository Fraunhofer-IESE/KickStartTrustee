  owl:members ( dtm-core:Actor
                dtm-core:DataTrusteeModel
                dtm-data:Architecture
                dtm-data:DataFlowComponent
                dtm-data:DataSystem
                dtm-data:ForwardingTechnique
                dtm-data:PreparationTechnique
                dtm-data:ReceptionTechnique
                dtm-data:SecurityReceptionTechnique
                dtm-data:StorageTechnique
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:AIPoweredAnalysis
                dtm-data:PrivacyEnhancingTechnology
                dtm-data:StatisticalAnalysis
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:API
                dtm-data:Analog
                dtm-data:Download
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:Aggregation
                dtm-data:Cleaning
                dtm-data:Transformation
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:Anonymisation
                dtm-data:AtRestEncryption
                dtm-data:E2EEncryption
                dtm-data:Pseudonymisation
                dtm-data:TransportEncryption
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:Continuous
                dtm-data:Manual
                dtm-data:Periodic
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( dtm-data:ForTransmissionOnly
